{
  "expo": {
    "name": "Medex",
    "slug": "medex",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "medex",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Medex uses on-device speech recognition to convert your voice into text.",
        "NSMicrophoneUsageDescription": "Medex needs microphone access so you can ask health questions by voice."
      },
      "bundleIdentifier": "com.srinidhi-23.medex"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.srinidhi_23.medex"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#151717",
          "dark": {
            "backgroundColor": "#151717"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Medex needs microphone access so you can ask health questions by voice.",
          "speechRecognitionPermission": "Medex uses on-device speech recognition to convert your voice into text."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
